
# LiveKit Cloud — from the Cloud dashboard (Settings → Keys)
LIVEKIT_URL=wss://<your-project>.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Sarvam — streaming STT (Saaras), get key from the Sarvam dashboard
SARVAM_API_KEY=

# Groq — LLM detector (Llama 3.3 70B), free tier
GROQ_API_KEY=

# Twilio creds not needed for the dial-in demo (Twilio → your webhook, static TwiML,
# SIP trunk configured in the console). Add TWILIO_AUTH_TOKEN only if you later
# validate webhook signatures or call the Twilio REST API.

# MongoDB — storage layer (docker-compose: service name; local dev: localhost:27017)
MONGODB_URI=mongodb://mongo:27017
MONGODB_DB=scamcall

# JWT signing secret for auth tokens — use a long random value in any real deploy
JWT_SECRET=dev-secret-change-me

