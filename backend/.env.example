
# LiveKit Cloud — from the Cloud dashboard (Settings → Keys)
LIVEKIT_URL=wss://<your-project>.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Sarvam — streaming STT (Saaras), get key from the Sarvam dashboard
SARVAM_API_KEY=

# Groq — LLM detector (Llama 3.3 70B), free tier
GROQ_API_KEY=

# Twilio DID (E.164) — the number callers dial; used in the TwiML Bin <Sip> URI
# and the LiveKit inbound trunk's numbers list.
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# SIP trunk auth — a secret pair you invent; must match the Twilio TwiML Bin <Sip>
# username/password and the LiveKit inbound trunk (lk sip inbound --auth-user/--auth-pass).
SIP_AUTH_USER=scamcall
SIP_AUTH_PASSWORD=

LIVEKIT_PROJECT_ID=
# Other Twilio creds not needed for the dial-in demo (static TwiML, SIP via console).
# Add TWILIO_AUTH_TOKEN only if you later validate webhook signatures or call the REST API.

# MongoDB — storage layer (docker-compose: service name; local dev: localhost:27017)
MONGODB_URI=mongodb://mongo:27017
MONGODB_DB=scamcall

# JWT signing secret for auth tokens — use a long random value in any real deploy
JWT_SECRET=dev-secret-change-me

# Link safety checker — both keys required for /link-check and the chat tool
# Google Safe Browsing v4: console.cloud.google.com → API & Services → Credentials
GOOGLE_SAFE_BROWSING_KEY=
# VirusTotal: virustotal.com → Profile → API Key (free tier: 4 req/min)
VIRUSTOTAL_KEY=

# Experimental URL classifier. Keep false — the current model flags real bank
# login pages as phishing. Needs a retrain + false-positive check first.
ML_URL_CLASSIFIER_ENABLED=false

